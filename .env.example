# Vapi
VAPI_API_KEY=

# Backend
PORT=8000

# Embedding (recupero semantico)
RAG_MODEL_NAME=intfloat/multilingual-e5-base

# Corpus RAG — usa il corpus reale scrappato (default)
# Per tornare al fallback: RAG_CORPUS_PATH=data/fallback_services.jsonl
RAG_CORPUS_PATH=data/services_cherasco.jsonl

# Pannello admin (/admin/appointments) — protezione HTTP Basic.
# Obbligatorie quando il backend è esposto via ngrok: se vuote il pannello
# resta disabilitato (503).
ADMIN_USER=
ADMIN_PASSWORD=
